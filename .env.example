# Checked — environment variables
# Copy to .env.local for local dev; set the same keys in Vercel Project Settings → Environment Variables.

# Phase 2 — Database (Neon Postgres, HTTP driver) + Auth (Clerk)
DATABASE_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional Clerk redirects (defaults are fine)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Custom items — AI-assisted classification (Groq, free tier)
# Get a key at https://console.groq.com/keys — no billing required for the free tier.
# GROQ_API_KEY=

# Phase 5 — Duty-Free (affiliate)
# NEXT_PUBLIC_AMAZON_ASSOCIATES_TAG=
